# Personal config for pdal-xcframework-builder.
# Copy to config.sh and edit. config.sh is gitignored.

# Path to the gdal.xcframework PDAL should link against.
# This is the xcframework produced by gdal-xcframework-builder.
GDAL_XCFRAMEWORK="/Users/mnmly/Development-local/Personal/SwiftPDAL/Frameworks/gdal.xcframework"

# Homebrew prefix for proj@9 (or compatible). proj.db is copied from here.
PROJ_PREFIX="$(brew --prefix proj@9 2>/dev/null || echo /opt/homebrew/opt/proj@9)"

# Optional: codesign identity. Leave empty to skip codesign.
CODESIGN_IDENTITY=""
# Example:
# CODESIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Where the final pdalcpp.xcframework + zip should be written.
OUTPUT_DIR="${OUTPUT_DIR:-$(pwd)/output}"

# Optional: mirror the xcframework into a Swift package's Frameworks dir.
SWIFT_PACKAGE_FRAMEWORKS_DIR=""
# Example:
# SWIFT_PACKAGE_FRAMEWORKS_DIR="/Users/you/Development-local/Personal/SwiftPDAL/Frameworks"

# Optional: GitHub repo (owner/name) for `make release`. Leave empty to skip.
GH_RELEASE_REPO=""

# Architectures (currently only arm64 is tested).
ARCHS="arm64"

# macOS deployment target.
DEPLOYMENT_TARGET="26.0"

# PDAL plugins to enable (space-separated, no BUILD_PLUGIN_ prefix).
ENABLED_PLUGINS="E57"

# Override the git tag if PDAL's tagging convention changes.
# Leave empty to auto-detect (<version> then v<version>).
PDAL_TAG=""

# Extra cmake flags appended to the configure step.
EXTRA_CMAKE_FLAGS=""

# ─── iOS slices (opt-in) ───────────────────────────────────────────────
# Set BUILD_IOS=1 to also build iOS device + simulator static slices
# alongside the macOS dynamic slice. Both build.sh and build_e57.sh
# honor this knob. The iOS slices are arm64-only and statically linked.
BUILD_IOS="${BUILD_IOS:-0}"

# iOS deployment target. Match gdal-xcframework-builder's setting —
# drift causes Mach-O LC_BUILD_VERSION mismatches.
IOS_DEPLOYMENT_TARGET="17.0"

# Path to proj.xcframework (iOS-only artifact from gdal-xcframework-builder).
# REQUIRED when BUILD_IOS=1. macOS keeps using PROJ_PREFIX above.
PROJ_XCFRAMEWORK=""
# Example:
# PROJ_XCFRAMEWORK="/Users/you/Development-local/Personal/SwiftPDAL/Frameworks/proj.xcframework"

# Path to E57Format.xcframework consumed by build.sh's iOS slices.
# Defaults to ${OUTPUT_DIR}/E57Format.xcframework, i.e. the artifact
# build_e57.sh produces in the same builder. Run build_e57.sh before
# build.sh when BUILD_IOS=1.
E57FORMAT_XCFRAMEWORK=""
